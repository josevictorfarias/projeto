<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Lista de Compras"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/edtItem"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Nome do item"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/edtQtd"
        android:padding="8dp"/>

    <EditText
        android:id="@+id/edtQtd"
        android:layout_width="88dp"
        android:layout_height="wrap_content"
        android:hint="Qtd"
        android:inputType="number"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="8dp"/>

    <LinearLayout
        android:id="@+id/linButtonsTop"
        android:orientation="horizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/edtItem"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Adicionar"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btnRemove"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Remover"
            android:layout_marginStart="8dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Limpar Tudo"
            android:layout_marginStart="8dp"
            android:layout_weight="1"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linButtonsBottom"
        android:orientation="horizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/linButtonsTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ordenar A→Z"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btnReverse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Inverter"
            android:layout_marginStart="8dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btnEdit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Atualizar"
            android:layout_marginStart="8dp"
            android:layout_weight="1"/>
    </LinearLayout>

    <ListView
        android:id="@+id/listView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:dividerHeight="1dp"
        app:layout_constraintTop_toBottomOf="@id/linButtonsBottom"
        app:layout_constraintBottom_toTopOf="@id/txtContador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtContador"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Total: 0 itens | Qtd total: 0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
